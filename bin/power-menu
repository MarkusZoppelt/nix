#!/usr/bin/env bash

# Function to show power menu
show_power_menu() {
  local menu_options="\u200B’ĆŻ Lock
\u200D’ŹÖ Relaunch
\u2060¾░£ē Restart
¾░Éź\u2063 Shutdown" # These first characters are invisible sort keys

  local selection=$(echo -e "$menu_options" | walker --dmenu -p "Power Options")

  case "$selection" in
  *Lock*) hyprlock ;;
  *Relaunch*) hyprctl dispatch exit ;;
  *Restart*) systemctl reboot ;;
  *Shutdown*) systemctl poweroff ;;
  esac
}

show_power_menu
